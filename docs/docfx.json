{
  "$schema": "https://raw.githubusercontent.com/dotnet/docfx/main/schemas/docfx.schema.json",

  "metadata": [
  {
    "src": [
      {
        "src": "../../.",
        "files": [
          "**/*.csproj"
        ]
      }
    ],
    "dest": "api",
    "filter": "filterConfig.yml"
  }
],

  "build": {
    "content": [
      {
        "files": [
          "**/*.{md,yml}"
        ],
        "exclude": [
          "_site/**"
        ]
      }
    ],
	"resource": [
      {
        "files": [
          "images/logo.svg" 
        ],
        "src": "."
      }
    ],
	
    "output": "../site",
    "template": [
      "default",
      "modern"
    ],
    "globalMetadata": {
      "_appName": "Opticon.csp2 .NET wrapper for the Opticon CSP2 library",
      "_appTitle": "Opticon.csp2 .NET wrapper for the Opticon CSP2 library",
	  "_appLogoPath": "images/logo.svg",
      "_enableSearch": true,
      "pdf": false
    }
  }
}